<?php
// --- 1. ЛОГИКА КЭШИРОВАНИЯ ГОРОДОВ ---
$cacheFile = 'cities_cache.txt';
$cities = ["Москва", "Санкт-Петербург", "Тула"]; // Запасной список

if (file_exists($cacheFile) && date('Y-m-d', filemtime($cacheFile)) === date('Y-m-d')) {
    $decoded = json_decode(file_get_contents($cacheFile), true);
    if (is_array($decoded)) $cities = $decoded;
} else {
    $response = @file_get_contents('https://exercise.develop.maximaster.ru/service/city/');
    if ($response) {
        $decoded = json_decode($response, true);
        if (is_array($decoded)) {
            $cities = $decoded;
            file_put_contents($cacheFile, $response);
        }
    }
}

// --- 2. ОБРАБОТКА POST-ЗАПРОСА (AJAX) ---
if (($_GET['action'] ?? '') === 'calculate') {
    header('Content-Type: application/json');
    $city = trim($_POST['city'] ?? '');
    $weight = trim($_POST['weight'] ?? '');

    if ($city === '' || !ctype_digit($weight)) {
        echo json_encode(['status' => 'error', 'message' => 'Выберите город и укажите вес числом.']);
        exit;
    }

    $url = 'https://exercise.develop.maximaster.ru/service/delivery/?' . http_build_query(['city' => $city, 'weight' => (int)$weight]);
    $apiResponse = @file_get_contents($url);
    
    echo $apiResponse ?: json_encode(['status' => 'error', 'message' => 'Ошибка сервера доставки.']);
    exit;
}
?>

