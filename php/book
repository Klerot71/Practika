<?php
$file = 'guestbook.csv';

// 1. Обработка отправки формы
if ($_SERVER['REQUEST_METHOD'] === 'POST' && !empty(trim($_POST['message']))) {
    $name = !empty(trim($_POST['name'])) ? htmlspecialchars(trim($_POST['name'])) : 'Анонимно';
    $message = htmlspecialchars(trim($_POST['message']));
    $date = date('d.m.Y H:i');
    $entry = "$date|$name|$message\n";
    file_put_contents($file, $entry, FILE_APPEND);
    header("Location: " . $_SERVER['PHP_SELF']); // Избегаем повторной отправки при обновлении
    exit;
}

// 2. Чтение сообщений
$messages = [];
if (file_exists($file)) {
    $lines = array_reverse(file($file, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES));
    foreach ($lines as $line) {
        $messages[] = explode('|', $line);
    }
}
?>

