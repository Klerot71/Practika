<?php
// Путь к файлу, где будет храниться число посещений
$file = 'counter.txt';

// Проверяем, существует ли файл, если нет — создаем его с начальным значением 0
if (!file_exists($file)) {
    file_put_contents($file, 0);
}

// Читаем текущее значение
$count = (int)file_get_contents($file);

// Увеличиваем счетчик
$count++;

// Сохраняем новое значение обратно в файл
file_put_contents($file, $count);

// Получаем текущее серверное время
$currentTime = date('H:i');
?>

<p>
    Страница была загружена <?php echo $count; ?> раз. 
    Текущее время <?php echo $currentTime; ?>.
</p>
