<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8">
    <title>Мониторинг CPU</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f5f5f5; display: flex; justify-content: center; padding: 30px; margin: 0; }
        .container { background-color: white; padding: 40px; border-radius: 15px; box-shadow: 0 4px 15px rgba(0,0,0,0.15); max-width: 900px; width: 100%; }
        h1 { text-align: center; color: #333; margin-top: 0; }
        .chart-container { position: relative; height: 400px; margin-bottom: 30px; }
        .stats { display: flex; justify-content: space-around; padding: 20px; background-color: #f9f9f9; border-radius: 10px; }
        .number { font-weight: bold; font-size: 24px; color: #333; text-align: center; }
        .label { color: #888; font-size: 14px; text-align: center; }
    </style>
</head>
<body>
    <div class="container">
        <h1>Загрузка процессора</h1>
        <div class="chart-container">
            <canvas id="cpuChart"></canvas>
        </div>
        <div class="stats">
            <div><div class="number" id="totalRequests">0</div><div class="label">Всего запросов</div></div>
            <div><div class="number" id="errorRequests">0</div><div class="label">Ошибок</div></div>
            <div><div class="number" id="errorPercent">0%</div><div class="label">Процент ошибок</div></div>
        </div>
    </div>

    <script>
        let chart;
        let totalRequests = 0;
        let errorRequests = 0;
        let lastValidValue = 0;

        // Инициализация графика
        function initChart() {
            const ctx = document.getElementById('cpuChart').getContext('2d');
            chart = new Chart(ctx, {
                type: 'line',
                data: { labels: [], datasets: [{ label: 'Загрузка (%)', data: [], borderColor: '#4CAF50', tension: 0.3, fill: true }] },
                options: { responsive: true, maintainAspectRatio: false, scales: { y: { min: 0, max: 100 } } }
            });
        }

        async function fetchData() {
            totalRequests++;
            try {
                const response = await fetch('https://exercise.develop.maximaster.ru/service/cpu/');
                const data = await response.json();

                if (data === 0) {
                    throw new Error('Ошибка сервиса');
                }
                lastValidValue = data;
                updateChart(data);
            } catch (err) {
                errorRequests++;
                updateChart(lastValidValue); // Выводим предыдущее значение
            }
            updateStats();
        }

        function updateChart(value) {
            const now = new Date().toLocaleTimeString();
            chart.data.labels.push(now);
            chart.data.datasets[0].data.push(value);
            
            if (chart.data.labels.length > 20) {
                chart.data.labels.shift();
                chart.data.datasets[0].data.shift();
            }
            chart.update();
        }

        function updateStats() {
            document.getElementById('totalRequests').textContent = totalRequests;
            document.getElementById('errorRequests').textContent = errorRequests;
            const percent = totalRequests > 0 ? (errorRequests / totalRequests) * 100 : 0;
            document.getElementById('errorPercent').textContent = percent.toFixed(1) + '%';
        }

        initChart();
        fetchData();
        setInterval(fetchData, 5000);
    </script>
</body>
</html>
