<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <style>
        body { 
            font-family: 'Segoe UI', sans-serif; 
            background-color: #f4f7f6; 
            display: flex; 
            justify-content: center; 
            align-items: center; 
            min-height: 100vh; 
            margin: 0; 
        }

        .order-form { 
            background: white; 
            padding: 30px; 
            border-radius: 15px; 
            box-shadow: 0 10px 25px rgba(0,0,0,0.1); 
            width: 400px; 
        }

        h2 { text-align: center; color: #333; }

        input, textarea { 
            width: 100%; 
            padding: 12px; 
            margin-bottom: 15px; 
            border: 1px solid #ccc; 
            border-radius: 8px; 
            box-sizing: border-box; 
        }

        #map { width: 100%; height: 250px; border-radius: 8px; margin-bottom: 5px; border: 1px solid #ccc; }
        
        /* Добавили стиль для вывода координат */
        #coordDisplay { font-size: 0.9em; color: #555; margin-bottom: 15px; font-style: italic; }

        button { 
            width: 100%; 
            padding: 12px; 
            background-color: #4a90e2; 
            color: white; 
            border: none; 
            border-radius: 8px; 
            font-weight: bold; 
            cursor: pointer; 
        }

        button:hover { background-color: #357abd; }

        #message { margin-top: 15px; font-weight: bold; text-align: center; }
    </style>
    <script src="https://api-maps.yandex.ru/2.1/?lang=ru_RU&apikey=ВАШ_API_КЛЮЧ"></script>
</head>
<body>

<div class="order-form">
    <h2>Оформление заказа</h2>
    <input type="text" id="fio" placeholder="ФИО">
    <input type="text" id="phone" placeholder="Телефон">
    <input type="text" id="email" placeholder="Email">
    
    <div id="map"></div>
    <div id="coordDisplay">Координаты: не выбраны</div>
    
    <textarea id="comment" maxlength="500" placeholder="Комментарий (макс. 500 символов)"></textarea>
    
    <button onclick="submitOrder()">Отправить</button>
    <div id="message"></div>
</div>

<script>
    let map, placemark;

    ymaps.ready(() => {
        map = new ymaps.Map("map", { center: [55.76, 37.64], zoom: 10 });
        
        map.events.add('click', (e) => {
            const coords = e.get('coords');
            
            if (placemark) map.geoObjects.remove(placemark);
            
            placemark = new ymaps.Placemark(coords, { balloonContent: "Точка доставки" });
            map.geoObjects.add(placemark);
            
            // Вывод координат с точностью до 6 знаков
            document.getElementById('coordDisplay').innerText = 
                `Координаты: ${coords[0].toFixed(6)}, ${coords[1].toFixed(6)}`;
        });
    });

    function submitOrder() {
        const msg = document.getElementById('message');
        msg.style.color = "red";
        
        if (!document.getElementById('fio').value) msg.innerText = "Заполните ФИО";
        else if (!/^\d+$/.test(document.getElementById('phone').value)) msg.innerText = "Телефон: только цифры";
        else if (!document.getElementById('email').value.includes('@')) msg.innerText = "Некорректный Email";
        else if (!placemark) msg.innerText = "Выберите точку на карте";
        else {
            msg.style.color = "green";
            msg.innerText = "Заказ успешно оформлен!";
        }
    }
</script>
</body>
</html>
